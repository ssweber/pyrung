{
  "name": "pyrung-debug",
  "displayName": "pyrung Debugger",
  "description": "Debug pyrung ladder logic through the Debug Adapter Protocol.",
  "version": "0.1.0",
  "publisher": "ssweber",
  "license": "MPL-2.0",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/ssweber/pyrung"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "scripts": {
    "test": "node --test --test-isolation=none"
  },
  "categories": [
    "Debuggers"
  ],
  "activationEvents": [
    "onDebug",
    "onCommand:pyrung.addMonitor",
    "onCommand:pyrung.removeMonitor",
    "onCommand:pyrung.findLabel",
    "onCommand:pyrung.monitorMenu",
    "onCommand:pyrung.toggleRapidStep",
    "onCommand:pyrung.configureRapidStep",
    "onCommand:pyrung.openGraph",
    "onCommand:pyrung.addToDataView"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "pyrung.addMonitor",
        "title": "pyrung: Add Monitor"
      },
      {
        "command": "pyrung.removeMonitor",
        "title": "pyrung: Remove Monitor"
      },
      {
        "command": "pyrung.findLabel",
        "title": "pyrung: Find Label"
      },
      {
        "command": "pyrung.monitorMenu",
        "title": "pyrung: Monitor Menu"
      },
      {
        "command": "pyrung.toggleRapidStep",
        "title": "pyrung: Toggle Rapid Step"
      },
      {
        "command": "pyrung.configureRapidStep",
        "title": "pyrung: Configure Rapid Step"
      },
      {
        "command": "pyrung.openGraph",
        "title": "pyrung: Open Graph View"
      },
      {
        "command": "pyrung.addToDataView",
        "title": "pyrung: Add to Data View"
      }
    ],
    "views": {
      "debug": [
        {
          "type": "webview",
          "id": "pyrung.historySlider",
          "name": "History",
          "when": "debugType == 'pyrung'"
        },
        {
          "type": "webview",
          "id": "pyrung.dataView",
          "name": "Data View",
          "when": "debugType == 'pyrung'"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "pyrung.addToDataView",
          "when": "debugType == 'pyrung'",
          "group": "pyrung"
        }
      ]
    },
    "breakpoints": [
      {
        "language": "python"
      }
    ],
    "debuggers": [
      {
        "type": "pyrung",
        "label": "pyrung",
        "languages": [
          "python"
        ],
        "runtime": "python",
        "runtimeArgs": [
          "-m",
          "pyrung.dap"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the Python file that constructs the Program or PLC."
              },
              "pythonPath": {
                "type": "string",
                "description": "Path to Python interpreter (e.g. .venv/bin/python). Defaults to 'python'."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "name": "Debug PLC Logic",
            "type": "pyrung",
            "request": "launch",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "pyrung: Debug PLC Logic",
            "description": "Launch pyrung DAP against a ladder logic script.",
            "body": {
              "name": "Debug PLC Logic",
              "type": "pyrung",
              "request": "launch",
              "program": "${file}"
            }
          }
        ]
      }
    ]
  }
}
